HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DEBUG=false

STORAGE_BACKEND=qdrant_postgres
DATABASE_URL=postgres://orag:orag@localhost:5432/orag?sslmode=disable

QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_USE_TLS=false
QDRANT_COLLECTION=orag_chunks
QDRANT_SEMANTIC_CACHE_COLLECTION=orag_semantic_cache
QDRANT_AUTO_CREATE_COLLECTIONS=true

JWT_SECRET=change-me
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin
AUTH_TOKEN_TTL=24h

ARK_API_KEY=
VOLCENGINE_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=doubao-seed-2-1-pro-260628
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215
ARK_EMBEDDING_DIMENSIONS=1024
LLM_CHAT_PROVIDER=volcengine
LLM_EMBEDDING_PROVIDER=volcengine
LLM_RERANK_PROVIDER=volcengine
LLM_MULTIMODAL_PROVIDER=volcengine
ALLOW_DETERMINISTIC_MOCK=false
RERANK_PROVIDER=volcengine
ARK_RERANK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_RERANK_MODEL=m3-v2-rerank
ALIYUN_RERANK_API_KEY=
ALIYUN_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
ALIYUN_RERANK_MODEL=qwen3-rerank
RERANK_INSTRUCT="Given a web search query, retrieve relevant passages that answer the query."
ARK_MULTIMODAL_MODEL=doubao-seed-2-1-pro-260628
ARK_TIMEOUT=60s
ARK_RETRY_TIMES=2
LIVE_ARK_TESTS=false

OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_CLOUD_BASE_URL=
GOOGLE_CLOUD_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
