# ORAG local development environment template.
# Copy to .env and fill real secrets before starting a non-test service.

# Service entrypoint
HOST=0.0.0.0
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DEBUG=false

# Storage backend
STORAGE_BACKEND=qdrant_postgres
DATABASE_URL=postgres://orag:orag@localhost:5432/orag?sslmode=disable

# Qdrant
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_USE_TLS=false
QDRANT_COLLECTION=orag_chunks
QDRANT_SEMANTIC_CACHE_COLLECTION=orag_semantic_cache
QDRANT_AUTO_CREATE_COLLECTIONS=true

# Auth
JWT_SECRET=orag-dev-secret-change-me
API_KEY_PEPPER=orag-dev-api-key-pepper-change-me
AUTH_TOKEN_TTL=24h
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin

# Model provider selection
# Real providers require their provider API key by default. For local tests
# without external model calls, switch every provider to mock and set
# ALLOW_DETERMINISTIC_MOCK=true explicitly.
LLM_CHAT_PROVIDER=volcengine
LLM_EMBEDDING_PROVIDER=volcengine
LLM_RERANK_PROVIDER=volcengine
LLM_MULTIMODAL_PROVIDER=volcengine
ALLOW_DETERMINISTIC_MOCK=false
# Compatibility/status flag only; it does not bypass selected provider key validation.
REQUIRE_EXTERNAL_PROVIDERS=false

# Ark / Doubao
ARK_API_KEY=
VOLCENGINE_API_KEY=
LLM_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=doubao-seed-2-1-pro-260628
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215
ARK_EMBEDDING_DIMENSIONS=1024
ARK_MULTIMODAL_MODEL=doubao-seed-2-1-pro-260628
ARK_TIMEOUT=60s
ARK_RETRY_TIMES=2
LIVE_ARK_TESTS=false

# Rerank
RERANK_PROVIDER=volcengine
ARK_RERANK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_RERANK_MODEL=m3-v2-rerank
ALIYUN_RERANK_API_KEY=
ALIYUN_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
ALIYUN_RERANK_MODEL=qwen3-rerank
DASHSCOPE_API_KEY=
RERANK_INSTRUCT="Given a web search query, retrieve relevant passages that answer the query."

# Optional provider API keys and required base URLs for selected providers.
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CLOUD_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_BASE_URL=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
BAICHUAN_API_KEY=
ZHIPU_API_KEY=
ZHIPUAI_API_KEY=
TONGYI_QIANWEN_API_KEY=
TENCENT_HUNYUAN_API_KEY=
HUNYUAN_API_KEY=
XUNFEI_SPARK_API_KEY=
SPARK_API_KEY=
BAIDU_YIYAN_API_KEY=
WENXIN_API_KEY=
XIAOMI_API_KEY=
PERPLEXITY_API_KEY=
VOYAGE_API_KEY=
JINA_API_KEY=

# RAG
RAG_DEFAULT_PROFILE=realtime
RAG_DENSE_TOP_K=50
RAG_SPARSE_TOP_K=50
RAG_RRF_K=60
RAG_RERANK_TOP_N=8
RAG_CONTEXT_TOP_N=8
RAG_MAX_CONTEXT_TOKENS=6000
RAG_SEMANTIC_CACHE_THRESHOLD=0.92
RAG_SEMANTIC_CACHE_MAX_ENTRIES=10000
RAG_QUERY_REWRITE_ENABLED=true
RAG_MULTI_QUERY_COUNT=3
RAG_HYDE_ENABLED=true
RAG_QUERY_ROUTER_ENABLED=false
RAG_QUERY_ROUTER_STRATEGY=heuristic
RAG_QUERY_ROUTER_DIRECT_MAX_RUNES=16
RAG_QUERY_ROUTER_COMPLEX_MIN_SIGNALS=2
RAG_GRAPH_RETRIEVAL_ENABLED=false
RAG_GRAPH_RETRIEVAL_TOP_K=8
RAG_NO_CONTEXT_ANSWER=未在知识库中检索到足够依据，无法基于上下文回答。
PROMPT_CACHE_MODE=auto

# Ingestion parser
INGEST_CHUNK_SIZE_TOKENS=800
INGEST_CHUNK_OVERLAP_TOKENS=120
INGEST_MAX_DOCUMENT_BYTES=26214400
INGEST_PARSER_METHOD=basic
INGEST_CONTEXTUAL_RETRIEVAL_ENABLED=false
INGEST_CONTEXTUAL_MAX_DOCUMENT_CHARS=12000
INGEST_CONTEXTUAL_MAX_CHUNK_CHARS=2000
INGEST_CONTEXTUAL_MAX_CONTEXT_CHARS=500
INGEST_CONTEXTUAL_FAILURE_MODE=fallback
INGEST_RAPTOR_ENABLED=false
INGEST_RAPTOR_BRANCH_FACTOR=4
INGEST_RAPTOR_MAX_LEVELS=2
INGEST_RAPTOR_MAX_SUMMARY_CHARS=1000
INGEST_GRAPH_MAX_ENTITIES_PER_CHUNK=6
MINERU_API_URL=
MINERU_APISERVER=
MINERU_SERVER_URL=
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=auto
MINERU_LANG=English
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
DOCLING_SERVER_URL=
DOCLING_TIMEOUT=10m

# Fail-fast execution budgets for synchronous expensive operations. Requests
# beyond concurrency return 429; admitted work receives this deadline context.
EXECUTION_INGESTION_TIMEOUT=10m
EXECUTION_INGESTION_CONCURRENCY=2
EXECUTION_QUERY_TIMEOUT=90s
EXECUTION_QUERY_CONCURRENCY=32
EXECUTION_EVALUATION_TIMEOUT=15m
EXECUTION_EVALUATION_CONCURRENCY=2
EXECUTION_RELEASE_TIMEOUT=30s
EXECUTION_RELEASE_CONCURRENCY=4

# Object storage
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET_NAME=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_SECRET=
OBJECT_STORAGE_CDN_DOMAIN=
OBJECT_STORAGE_MOCK_UPLOAD=true

# Public, anonymous-read tutorial package catalog. No AccessKey is required.
TUTORIAL_CATALOG_BASE_URL=https://orag.oss-cn-guangzhou.aliyuncs.com/tutorial-packs
TUTORIAL_MAX_MANIFEST_BYTES=4194304
TUTORIAL_MAX_OBJECT_BYTES=34359738368
TUTORIAL_HTTP_TIMEOUT=2m
# local is development/test only. Production tutorial outputs should use a
# separate private OBJECT_STORAGE_BUCKET_NAME with provider aliyun_oss.
TUTORIAL_PRIVATE_OUTPUT_DIR=./.orag/tutorial-packs
TUTORIAL_PRIVATE_OUTPUT_PREFIX=tutorial-experiments

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
# Parent-based root trace sampling ratio in [0,1]. Keep 1 unless the Collector
# has a deliberate retention/tail-sampling policy.
OTEL_TRACES_SAMPLER_ARG=1
# OTLP resource service.name.
OTEL_SERVICE_NAME=orag
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OBSERVABILITY_RECORD_PROMPTS=false
