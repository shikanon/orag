{
  "annotations": {"list": []},
  "description": "Operational overview for ORAG's documented low-cardinality Prometheus metrics. Import it after configuring a Prometheus datasource.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(orag_up)", "refId": "A"}],
      "title": "API availability",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 9, "x": 6, "y": 0},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum(rate(orag_http_requests_total[$__rate_interval]))", "legendFormat": "requests", "refId": "A"},
        {"expr": "sum(rate(orag_http_errors_total{status_class=~\"5xx\"}[$__rate_interval]))", "legendFormat": "5xx", "refId": "B"}
      ],
      "title": "HTTP request and 5xx rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 9, "x": 15, "y": 0},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(orag_http_request_latency_ms_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "A"}],
      "title": "HTTP latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum(rate(orag_rag_queries_total[$__rate_interval])) by (outcome, cache_status)", "legendFormat": "{{outcome}} / {{cache_status}}", "refId": "A"}],
      "title": "RAG outcomes and cache status",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(orag_rag_query_latency_ms_bucket[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "A"}],
      "title": "RAG latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum(increase(orag_dependency_checks_total[$__rate_interval])) by (dependency, status)", "legendFormat": "{{dependency}} / {{status}}", "refId": "A"}],
      "title": "Dependency readiness checks",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum(increase(orag_trace_store_total[$__rate_interval])) by (outcome)", "legendFormat": "{{outcome}}", "refId": "A"}],
      "title": "Trace-store outcomes",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["orag", "prometheus", "rag"],
  "templating": {"list": [{"current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"}]},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "ORAG Overview",
  "uid": "orag-overview",
  "version": 1
}
