OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OBSERVABILITY_RECORD_PROMPTS=false
